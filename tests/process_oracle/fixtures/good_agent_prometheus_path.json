      "observation": {
        "results": [
          {"source_call_id": "tc1", "content": "[{\"labels\":{\"alertname\":\"ContainerCPUThrottling\",\"container\":\"geo\",\"namespace\":\"hotel-reservation\",\"severity\":\"warning\"},\"state\":\"firing\",\"annotations\":{\"description\":\"geo container throttled at 74.98%\"}}]"}
